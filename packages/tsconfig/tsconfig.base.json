//关注于解析策略，严格模式，跳过库检查，ES互操作性
{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    // 模块解析策略 vitebun 使用bundler ，nodenext就是导入需要加上后缀
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleDetection": "force",
    "resolveJsonModule": true
  }
}
