{
  "name": "@pori15/logixlysia",
  "version": "6.0.15",
  "description": "🦊 Logixlysia is a logger for Elysia",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bunup --watch",
    "build": "bunup",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "clean": "git clean -fdx .turbo dist node_modules coverage",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "release": "bun pm version patch && bun  publish --registry=https://registry.npmjs.org/ --access public"
  },
  "author": "Noppakorn Kaewsalabnil <hello@pungrumpy.com>",
  "bugs": {
    "url": "https://github.com/pori15/logixlysia/issues"
  },
  "homepage": "https://logixlysia.vercel.app",
  "keywords": [
    "logixlysia",
    "elysiajs",
    "logger"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://https://github.com/pori15/logixlysia.git"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "^1.3.11",
    "bunup": "^0.16.31",
    "elysia": "^1.4.28",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "elysia": "^1.4.28",
    "pino-pretty": ">=13.0.0",
    "typescript": "^6.0.2"
  },
  "peerDependenciesMeta": {
    "pino-pretty": {
      "optional": true
    }
  }
}
